/* pages/product-detail/product-detail.wxss */
.container {
  background-color: #fff;
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* 1. Hero 区域 */
.product-hero {
  position: relative;
  width: 100%;
  height: 600rpx;
}

.hero-bg {
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
}

.badge-container {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.student-medal {
  background: #ffc107;
  padding: 6rpx 16rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
}

.student-medal image {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
}

.student-medal text {
  font-size: 20rpx;
  font-weight: bold;
  color: #000;
}

.geo-badge {
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  padding: 6rpx 16rpx;
  border-radius: 30rpx;
  color: #fff;
  font-size: 20rpx;
}

.hero-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.hero-origin {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 10rpx;
  display: block;
}

/* 价格条 */
.price-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  background: #f8f9fa;
}

.price-left {
  display: flex;
  align-items: baseline;
}

.price-left .symbol { font-size: 32rpx; color: #d32f2f; }
.price-left .num { font-size: 56rpx; font-weight: bold; color: #d32f2f; }
.price-left .unit { font-size: 26rpx; color: #999; margin-left: 4rpx; }

.price-right { display: flex; gap: 12rpx; }
.price-right .tag {
  font-size: 20rpx;
  color: #07c160;
  border: 1rpx solid #07c160;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

/* 2. 故事轴 Timeline */
.story-section { padding: 40rpx; }
.story-header { margin-bottom: 40rpx; }
.story-title { font-size: 40rpx; font-weight: bold; display: block; }
.story-subtitle { font-size: 24rpx; color: #999; margin-top: 8rpx; display: block; }

.timeline-item { display: flex; min-height: 200rpx; }

/* 左侧：日期 */
.time-column {
  width: 100rpx;
  flex-shrink: 0;
  text-align: right;
  padding-right: 30rpx;
}
.time-column .date { font-size: 28rpx; font-weight: bold; display: block; }
.time-column .time { font-size: 20rpx; color: #999; display: block; margin-top: 4rpx; }

/* 中间：轴线 */
.axis-column {
  width: 40rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.node {
  width: 20rpx;
  height: 20rpx;
  background: #07c160;
  border-radius: 50%;
  border: 6rpx solid #e8f5e9;
  z-index: 2;
}
.line {
  flex: 1;
  width: 2rpx;
  background: #eee;
  margin: -10rpx 0;
}

/* 右侧：内容 */
.content-column { flex: 1; padding-bottom: 60rpx; }
.story-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.location-tag {
  background: #333;
  padding: 10rpx 20rpx;
  display: flex;
  align-items: center;
}
.location-tag image { width: 24rpx; height: 24rpx; margin-right: 8rpx; }
.location-tag text { font-size: 22rpx; color: #fff; }

.media-preview image, .media-preview video {
  width: 100%;
  height: 400rpx;
}

.fade-in {
  animation: fadeIn 0.8s ease-in-out;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.story-text { padding: 24rpx; font-size: 28rpx; line-height: 1.6; color: #333; }

.farmer-info {
  padding: 20rpx 24rpx;
  background: #fcfcfc;
  display: flex;
  align-items: center;
  border-top: 1rpx solid #f5f5f5;
}
.farmer-avatar { width: 36rpx; height: 36rpx; border-radius: 50%; margin-right: 12rpx; }
.farmer-info text { font-size: 22rpx; color: #999; }

/* 3. 底部浮动工具栏 */
.float-toolbar {
  position: fixed;
  bottom: 40rpx;
  left: 40rpx;
  right: 40rpx;
  display: flex;
  gap: 20rpx;
  z-index: 99;
}

.action-btn {
  flex: 1;
  height: 100rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
}

.action-btn.call { background: #07c160; }
.action-btn.wechat { background: #000; }
.action-btn image { width: 36rpx; height: 36rpx; margin-right: 12rpx; }

/* 安全弹窗 */
.security-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 60rpx;
}
.security-modal {
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx;
  width: 100%;
}
.modal-header { font-size: 36rpx; font-weight: bold; text-align: center; margin-bottom: 30rpx; }
.modal-body { font-size: 28rpx; color: #666; line-height: 1.6; margin-bottom: 40rpx; }
.confirm-btn {
  background: #07c160 !important;
  color: #fff !important;
  border-radius: 44rpx !important;
  font-size: 30rpx !important;
}
