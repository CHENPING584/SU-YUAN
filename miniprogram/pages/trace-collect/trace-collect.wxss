.container {
  padding: 0 0 120rpx 0;
  background-color: #fff;
  min-height: 100vh;
}

/* 通告栏 */
.notice-bar {
  background-color: #fff3e0;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #ef6c00;
  position: sticky;
  top: 0;
  z-index: 100;
}

.notice-bar icon {
  margin-right: 12rpx;
}

.header {
  padding: 60rpx 40rpx;
}

.title {
  font-size: 56rpx;
  font-weight: 900;
  color: #000;
  display: block;
}

.desc {
  font-size: 32rpx;
  color: #666;
  margin-top: 20rpx;
  display: block;
}

.card {
  margin: 0 40rpx 40rpx;
  padding: 40rpx;
  background: #f8f9fa;
  border-radius: 24rpx;
}

.card-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  color: #333;
}

/* 拍摄区域 */
.media-container {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.media-box {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.media-box image, .media-box video {
  width: 100%;
  height: 100%;
}

.del-tag {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 0, 0, 0.7);
  color: #fff;
  font-size: 24rpx;
  text-align: center;
  padding: 8rpx 0;
}

.btn-capture {
  width: 200rpx;
  height: 200rpx;
  background: #fff;
  border: 4rpx solid #000;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.btn-capture image {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 10rpx;
}

.btn-capture text {
  font-size: 28rpx;
  font-weight: bold;
}

/* 语音描述 */
.desc-input {
  width: 100%;
  height: 240rpx;
  background: #fff;
  padding: 24rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  font-size: 36rpx;
  margin-bottom: 30rpx;
  border: 2rpx solid #eee;
}

.voice-btn {
  height: 120rpx;
  background: #000;
  color: #fff;
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  transition: all 0.2s;
}

.voice-btn.active {
  background: #07c160;
  transform: scale(0.98);
}

.voice-btn image {
  width: 48rpx;
  height: 48rpx;
  margin-right: 20rpx;
}

/* 底部按钮 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx 40rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
}

.main-submit-btn {
  height: 110rpx !important;
  line-height: 110rpx !important;
  background: #07c160 !important;
  color: #fff !important;
  font-size: 40rpx !important;
  font-weight: bold !important;
  border-radius: 55rpx !important;
}
