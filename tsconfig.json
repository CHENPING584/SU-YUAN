{
  "compilerOptions": {
    "strict": true,
    "module": "ESNext",
    "target": "ES6",
    "lib": ["ES6", "DOM"],
    "moduleResolution": "node",
    "skipLibCheck": true,
    "sourceMap": true,
    "noImplicitAny": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "/*": ["./miniprogram/*"]
    },
    "types": [
      "miniprogram-api-typings"
    ]
  },
  "include": [
    "miniprogram/**/*.ts",
    "typings/**/*.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}